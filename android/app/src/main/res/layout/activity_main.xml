<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/backgroundColor">

    <!-- App Identity -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Usque VPN"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cloudflare WARP / MASQUE"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="32dp" />

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cardBackground"
        android:padding="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/statusDisconnected"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="16dp"
            android:layout_bottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTERNAL IP"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:textAllCaps="true"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/ip_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not registered"
            android:textSize="14sp"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Configuration Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginBottom="24dp">
        <TextView
            android:id="@+id/sni_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SNI: Loading..."
            android:textSize="12sp"
            android:textColor="@color/textSecondary" />
        <TextView
            android:id="@+id/endpoint_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Endpoint: Loading..."
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/settings_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Settings"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/connect_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Connect"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
