<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SNI (Server Name Indication)"
        android:textColor="@color/textSecondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/sni_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. www.visa.com.cn"
        android:inputType="textUri"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Endpoint (host:port)"
        android:textColor="@color/textSecondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/endpoint_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 162.159.198.1:443"
        android:inputType="textUri"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Supported formats:\n- IPv4: 162.159.198.1:443\n- IPv6: [2606:4700:103::1]:443\n- Automatic .1/.2 fallback supported."
        android:textColor="@color/textSecondary"
        android:textSize="11sp"
        android:lineSpacingExtra="2dp" />

</LinearLayout>
